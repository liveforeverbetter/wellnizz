        "pages": [
          "api-reference/introduction",
          {
            "group": "Start and authenticate",
            "pages": [
              "GET /health",
              "GET /ready",
              "GET /version",
              "GET /capabilities",
              "GET /endpoints",
              "GET /openapi.json",
              "POST /sandbox/sessions",
              "POST /sandbox/hero",
              "POST /auth/otp/start",
              "POST /auth/otp/verify",
              "POST /api-keys"
            ]
          },
          {
            "group": "Ingest and connect",
            "pages": [
              "POST /imports/file",
