      "href": "https://api.foreverbetter.xyz/dashboard"
    }
  },
  "api": {
    "baseUrl": "https://api.foreverbetter.xyz",
    "auth": {
      "method": "bearer"
    },
    "playground": {
      "mode": "show"
    }
  },
