          "highlight_reason": "Highlights deviation from personal baseline rather than a universal target.",
          "states": [
            "near baseline",
            "above baseline",
            "below baseline",
            "missing"
          ]
        },
        {
          "id": "blood_pressure",
          "label": "Blood pressure",
          "modality": "wearables",
          "priority": "secondary",
          "format": "systolic/diastolic",
          "preferred_visual": "monitor_tile",
          "highlight_reason": "Only show when source and measurement context are explicit.",
          "states": ["within target", "watch", "missing"]
        },
        {
          "id": "apo_b",
          "label": "ApoB",
          "modality": "biomarkers",
          "priority": "context",
          "format": "value + unit + lab range",
          "preferred_visual": "range_bar",
          "highlight_reason": "A slower-moving cardiovascular context signal.",
          "states": ["in range", "watch", "out of range", "missing"]
        },
        {
          "id": "hba1c",
          "label": "HbA1c",
          "modality": "biomarkers",
          "priority": "context",
          "format": "percentage + lab range",
          "preferred_visual": "range_bar",
          "highlight_reason": "Metabolic context with collection date visible.",
          "states": ["in range", "watch", "out of range", "missing"]
        },
        {
          "id": "inflammation",
          "label": "Inflammation",
          "modality": "biomarkers",
          "priority": "context",
          "format": "marker set + trend",
          "preferred_visual": "metric_table",
          "highlight_reason": "A retestable explanation for persistent low recovery without turning one marker into a diagnosis.",
          "states": ["quiet", "watch", "elevated", "missing"]
        },
        {
          "id": "training_response",
          "label": "Training response",
          "modality": "genetics",
          "priority": "context",
          "format": "evidence-graded context",
          "preferred_visual": "context_card",
          "highlight_reason": "Tunes training questions but never overrides observed data.",
          "states": [
            "supportive context",
            "mixed evidence",
            "no signal",
            "not provided"
          ]
        },
        {
          "id": "daily_context",
          "label": "Daily context",
          "modality": "health-context",
          "priority": "primary",
          "format": "structured note + tags",
          "preferred_visual": "context_strip",
          "highlight_reason": "Captures illness, travel, alcohol, stress, pain, and goals sensors cannot infer.",
          "states": ["captured", "partial", "not captured"]
        }
