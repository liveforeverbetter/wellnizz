          "highlight_reason": "Useful when it moves away from personal baseline.",
          "states": ["within baseline", "elevated", "low", "missing"]
        },
        {
          "id": "blood_oxygen",
          "label": "Blood oxygen",
          "modality": "wearables",
          "priority": "secondary",
          "format": "percentage",
          "preferred_visual": "monitor_tile",
