      "animations": [
        {
          "id": "hero-gauge-sweep",
          "trigger": "page load or date change",
          "motion": "Animate each semicircular gauge from empty to value with a 60ms stagger.",
          "duration": "1200ms entrance + 60ms stagger",
          "reduced_motion": "Render the final arc immediately."
        },
        {
          "id": "healthspan-particle-orb",
          "trigger": "hero visible and long-horizon insight is present",
          "motion": "Slow, low-opacity particles orbit a green radial orb.",
          "duration": "12–18s ambient loop",
          "reduced_motion": "Use a static radial glow."
        },
        {
          "id": "metric-count-in",
          "trigger": "metric card enters viewport",
          "motion": "Count numeric values once, then reveal baseline delta and freshness.",
          "duration": "360ms",
          "reduced_motion": "Show final value immediately."
        },
        {
          "id": "bar-growth",
          "trigger": "section enters viewport",
          "motion": "Grow status-colored load, sleep, stress, and range bars from zero.",
          "duration": "480ms",
          "reduced_motion": "Show final width immediately."
        },
        {
          "id": "focus-reveal",
          "trigger": "action plan enters viewport",
          "motion": "Reveal FOCUS items in priority order with a short vertical slide.",
          "duration": "240ms per item",
          "reduced_motion": "Render all actions immediately."
        },
        {
          "id": "source-refresh",
          "trigger": "sync completes",
          "motion": "Pulse the source chip once, update freshness, and crossfade changed values.",
          "duration": "200ms",
          "reduced_motion": "Update values without pulsing."
        }
      ],
      "action_plan": {
        "title": "FOCUS",
        "voice": "Direct coach: specific, calm, and non-judgmental. Say what to do next and why it matters today.",
        "ranking": "Rank by immediate safety and expected recovery impact, then confidence and ease. Recovery constrains strain recommendations; observed data outranks genetic context.",
        "cadence": ["Now", "Today", "Tonight", "This week", "Retest"],
        "item_fields": [
          "priority",
          "title",
          "why_now",
          "steps",
          "target_metric",
          "expected_check_in",
          "source_ids",
          "confidence",
          "safety_note",
          "status"
        ],
        "stages": [
          "FOCUS: one to three next actions",
          "MAINTAIN: habits supporting the signal",
          "WATCH: what changes the recommendation",
          "RETEST: when to measure again"
        ],
        "safety_boundary": "Wellness education only. Do not diagnose, prescribe, or tell someone to train through concerning symptoms; route high-stakes findings to a qualified clinician."
      },
