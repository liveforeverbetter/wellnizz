      "responsive": {
        "breakpoints": [
          "<=720px mobile",
          "721-1024px tablet",
          ">1024px desktop"
        ],
        "desktop": "Three hero gauges in one row; health-monitor metrics in a 2–3 column grid; slower biomarker and genetic context follows the live wearable signal; action plan stays visible below the hero.",
        "tablet": "Keep gauges in two rows, use two-column monitor cards, and keep source chips visible beside section headers.",
        "mobile": "Stack recovery, sleep, and strain in that order; use one-column monitor cards with values left and sparklines right; collapse optional genetics behind disclosure rows."
