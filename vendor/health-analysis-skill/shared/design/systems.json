            "severity",
            "duration",
            "goal_id",
            "source"
          ]
        },
        "freshness_rule": "Show observation window and last sync beside every live score; never imply a current score when the source is stale.",
        "missing_data_rule": "Use an explicit not-connected or not-provided state and preserve section order as modalities are added."
      },
      "components": {
