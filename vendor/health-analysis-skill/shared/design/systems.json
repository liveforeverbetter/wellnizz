        {
          "id": "health-context",
          "label": "Daily context",
          "modality": "health-context",
          "purpose": "Capture symptoms, illness, travel, alcohol, stress, pain, schedule, goals, and perceived exertion.",
          "component": "context_strip + check_in_form",
          "required_fields": [
            "recorded_at",
            "context_type",
            "value_or_note",
            "source"
          ],
          "optional_fields": [
            "severity",
            "duration",
            "goal_id",
            "related_activity_id"
          ],
          "empty_state": "Add a short check-in when the dashboard misses the why behind a score.",
          "responsive_behavior": "Use quick tags on mobile and a timeline/filterable context rail on desktop."
        }
