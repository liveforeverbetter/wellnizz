{
  "name": "@foreverbetter/longevity-api",
  "version": "0.4.8",
  "description": "Self-hostable wellness data API and MCP service for genomics, biomarkers, wearables, and lab discovery.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "migrate": "node dist/db/migrate.js",
    "production:smoke": "node scripts/production-smoke.mjs",
    "labs:sync": "node scripts/sync-lab-locations.mjs",
    "e2e:scenario": "node scripts/e2e-scenario.mjs",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "docs:validate": "npm run openapi:generate && cd docs && PUPPETEER_SKIP_DOWNLOAD=1 npx --yes --package=node@22 --package=mint@4.2.700 -c 'mint validate'",
    "docs:dev": "npm run openapi:generate && cd docs && PUPPETEER_SKIP_DOWNLOAD=1 npx --yes --package=node@22 --package=mint@4.2.700 -c 'mint dev'",
    "demos:record": "node scripts/record-readme-demos.mjs",
    "skill:bundle": "bash scripts/bundle-health-skill.sh",
    "skill:verify": "node scripts/verify-health-skill-bundle.mjs",
    "skill:verify:fresh": "node scripts/verify-health-skill-bundle.mjs --require-source",
    "package:verify": "node scripts/verify-package-contents.mjs",
    "start": "node dist/index.js",
    "worker:wearables": "tsx src/workers/wearables-worker.ts",
    "worker:wearables:once": "tsx src/workers/wearables-worker.ts --once",
    "worker:wgs": "tsx src/workers/genetics-worker.ts",
    "worker:wgs:once": "tsx src/workers/genetics-worker.ts --once",
    "test": "tsx --test test/*.test.ts",
    "kb:build": "node scripts/build-kb.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@coinbase/x402": "^2.1.0",
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "@x402/extensions": "^2.18.0",
    "@x402/svm": "^2.18.0",
    "jose": "^6.2.3",
    "nodemailer": "9.0.3",
    "pg": "^8.22.0",
    "tsx": "4.23.1",
    "unpdf": "^1.6.2"
  }
}
