# Wellnizz API configuration. Copy to .env and fill in the secrets.
#   cp .env.example .env
# Generate any secret with:  openssl rand -hex 32
# Production startup rejects missing, short, or unchanged placeholder secrets.

# ─── Core (required) ─────────────────────────────────────────────────────────

# Postgres. docker-compose builds DATABASE_URL from these; set a real password.
POSTGRES_USER=health
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=health

# If you run Postgres yourself (not via docker-compose), set DATABASE_URL directly:
# DATABASE_URL=postgres://user:pass@host:5432/health
# For remote Postgres, require verified TLS. If the server uses a private CA,
# paste its PEM text into DATABASE_SSL_CA with newlines encoded as \n.
# DATABASE_SSL=require
# DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# Store + payload storage. Defaults suit the docker-compose stack.
STORE_MODE=postgres
STORAGE_DRIVER=filesystem
PAYLOAD_DIR=/data/payloads

# ─── Auth (required) ─────────────────────────────────────────────────────────
# Signs self-issued API keys and email sign-in sessions. Set a strong secret.
API_KEY_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# Agent-login issues a durable API key. Defaults to 365 days; allowed values
# are clamped to 180–730 days. The browser handoff code remains short-lived.
AGENT_API_KEY_TTL_DAYS=365

# AUTH_MODE controls how bearer tokens are verified:
#   service_account - HS256 tokens signed with SERVICE_ACCOUNT_JWT_SECRET (self-hosted default)
#   oidc            - validate against an external OIDC issuer (AUTH_ISSUER/AUTH_JWKS_URI)
#   disabled        - no auth; local development only, never in production
AUTH_MODE=service_account
# Agents with health:data:read can read and query all data belonging to their
# authenticated user without enumerating every read endpoint. Set false only
# for deployments that require strict per-read endpoint grants.
AGENT_FULL_USER_DATA_READS=true
SERVICE_ACCOUNT_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# New keys use foreverbetter-api. The legacy audiences remain accepted so
# existing keys continue to work while clients migrate.
AUTH_AUDIENCE=foreverbetter-api,longevity-api,health-api
# AUTH_ISSUER=
# AUTH_JWKS_URI=
# AUTH_JWT_ALGORITHMS=RS256,ES256

# Comma-separated browser origins allowed to call the API (dashboard). Empty =
# closed (server-to-server callers and agents that send no Origin are unaffected).
CORS_ALLOWED_ORIGINS=
# CORS_ALLOWED_ORIGIN_PATTERNS=
# Public base URL of this deployment, used to build links in responses.
PUBLIC_BASE_URL=http://localhost:8787
DOCS_URL=https://foreverbetter.mintlify.app
REQUIRE_HTTPS=false

NODE_ENV=production
PORT=8787

# ─── Email sign-in (optional) ────────────────────────────────────────────────
# console = print the code to server logs (zero-config, development only)
# resend  = send via the Resend HTTP API (set RESEND_API_KEY)
# smtp    = send via SMTP (set SMTP_* or SMTP_URL); point at Mailpit for testing
# none    = disable email sign-in entirely
EMAIL_DRIVER=none
# EMAIL_FROM must be a verified sender for resend/smtp.
EMAIL_FROM=Wellnizz <login@localhost>
# Display name used in the sign-in subject and HTML template.
EMAIL_BRAND=Wellnizz
# Optional narrow hosted billing bypass. These do not grant health:admin or
# cross-user data access. Use trusted operator email and/or stable user ID lists
# only; keep them as deployment secrets in production.
# HEALTH_API_BILLING_ADMIN_EMAILS=james@example.com
# HEALTH_API_BILLING_ADMIN_USER_IDS=usr_...
# Full administrative access (health:admin) for the listed operator emails.
# Applies to any token carrying that verified email, including agent API keys
# minted from it. Keep this list short and treat it as a deployment secret.
# HEALTH_API_ADMIN_EMAILS=operator@example.com
# RESEND_API_KEY=re_...
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# App-store review bypass (a fixed code for a reviewer with no inbox):
# REVIEW_LOGIN_EMAIL=
# REVIEW_LOGIN_CODE=

# ─── S3 object storage (optional; STORAGE_DRIVER=s3) ─────────────────────────
# Works with MinIO (docker compose --profile s3) or any S3-compatible service.
# S3_BUCKET=health-api-payloads
# S3_ENDPOINT=http://minio:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=generate-a-unique-access-key
# S3_SECRET_ACCESS_KEY=generate-with-openssl-rand-hex-32
# S3_FORCE_PATH_STYLE=true

# ─── Wearables (optional; bring your own developer credentials) ──────────────
# Register apps with WHOOP / Oura and paste their OAuth credentials to enable
# one-click connections. Without them, users supply their own access tokens.
# WHOOP_CLIENT_ID=
# WHOOP_CLIENT_SECRET=
# WHOOP_REDIRECT_URI=
# Encrypts stored OAuth tokens at rest (base64 32 bytes: openssl rand -base64 32)
# WHOOP_TOKEN_ENC_KEY=
# OURA_CLIENT_ID=
# OURA_CLIENT_SECRET=
# OURA_REDIRECT_URI=
# OURA_WEBHOOK_VERIFICATION_TOKEN=
# WEARABLE_SYNC_MAX_ATTEMPTS=5
# WEARABLE_SYNC_WORKER_POLL_MS=10000

# ─── Billing (explicit opt-in; disabled by default) ─────────────────────────
# This is the single conscious switch for any money-collection feature.
# Stripe and x402 remain OFF unless it is exactly true, even if their secrets
# or recipient addresses are present. Self-hosters can leave this false.
BILLING_ENABLED=false

# ─── Hosted Stripe billing (optional; cloud deployments only) ────────────────
# With BILLING_ENABLED=true, all values below enable Checkout and the portal.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STANDARD=price_...  # $9.99/month recurring
# STRIPE_PRICE_BUILDER=price_...   # $24.99/month recurring
# STRIPE_PRICE_GROWTH=price_...    # $49/month recurring (highest self-serve tier)
# STRIPE_BILLING_RETURN_URL=https://api.example.com/dashboard
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_...
# STRIPE_WEBHOOK_ENDPOINT_ID=we_...

# ─── x402 agent micropayments (optional) ────────────────────────────────────
# Lets agents pay selected routes per request without creating an API key.
# Requires BOTH BILLING_ENABLED=true and X402_ENABLED=true. Production requires
# facilitator(s) that collectively advertise every enabled CAIP-2 network.
X402_ENABLED=false
X402_NETWORKS=base,polygon,solana
# One or more x402 v2 facilitator base URLs, comma separated. The public
# x402.org facilitator is testnet-only; choose production facilitators for
# Base (eip155:8453), Polygon (eip155:137), and Solana mainnet.
# X402_FACILITATOR_URLS=https://facilitator-one.example,https://facilitator-two.example
# Coinbase's production facilitator signs each request dynamically. When its
# URL is present, configure both credentials as deployment secrets.
# CDP_API_KEY_ID=organizations/.../apiKeys/...
# CDP_API_KEY_SECRET=...
# Merchant USDC recipient addresses. Base and Polygon use the same EVM address.
# X402_EVM_PAY_TO=0x...
# X402_SOLANA_PAY_TO=...
# Optional public canonical URL when it differs from PUBLIC_BASE_URL.
# X402_PUBLIC_BASE_URL=https://api.example.com
# Optional per-route overrides keyed by endpoint ID or "METHOD /route/:param".
# X402_ROUTE_PRICES={"imports.file":"$0.02","analyses.create":"$0.05","genetics.ancestry.create":"$0.10"}
# Optional JSON map from facilitator URL to static request headers. Store this
# as a secret, never in source control.
# X402_FACILITATOR_AUTH_HEADERS={"https://facilitator.example":{"Authorization":"Bearer ..."}}

# ─── Lab discovery (optional) ────────────────────────────────────────────────
# Without keys, lab search returns official locator handoff URLs.
# QUEST_LOCATIONS_API_KEY=
# QUEST_YEXT_EXPERIENCE_KEY=
# SYNLAB_API_KEY=

# ─── Genetics analysis (optional tuning) ─────────────────────────────────────
# HEALTH_ANALYSIS_EXECUTION_MODE=queue
# HEALTH_ANALYSIS_TIMEOUT_MS=1800000
# Full dbSNP annotation of a WGS upload can take hours on the dedicated worker.
# HEALTH_ANALYSIS_FULL_DBSNP_TIMEOUT_MS=14400000
# HEALTH_ANALYSIS_MAX_ATTEMPTS=3
# MAX_GENETICS_UPLOAD_BYTES=536870912
# Short-lived S3 PUT URL for direct VCF/SNP/23andMe uploads (60-86400 seconds).
# GENETICS_UPLOAD_URL_TTL_SECONDS=3600

# ─── Limits & audit (optional) ───────────────────────────────────────────────
MAX_BODY_BYTES=10485760
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUDIT_IP_HASH_SALT=change-me-random-log-salt
# HEALTH_API_ROUTE_OVERRIDES={"POST /imports/file":{"max_body_bytes":52428800}}
# HEALTH_API_USER_QUOTAS={"imports.file":{"window_ms":86400000,"max":50}}

# ─── Outbound webhooks (optional) ────────────────────────────────────────────
# HEALTH_API_WEBHOOK_URL=
# Production delivery requires HTTPS and a secret of at least 32 characters.
# HEALTH_API_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# ─── Published image (optional) ──────────────────────────────────────────────
# IMAGE=ghcr.io/liveforeverbetter/foreverbetter
# IMAGE_TAG=latest
